            @Card()
        </div>
        <div class="w-full sm:w-[calc(50%-12px)]">
            @Card()
        </div>
        <div class="w-full sm:w-[calc(50%-12px)]">
            @Card()
        </div>
        <div class="w-full sm:w-[calc(50%-12px)]">
            @Card()
        </div>
        <div class="w-full sm:w-[calc(50%-12px)]">
